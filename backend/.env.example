# Copy to .env and adjust. python-dotenv loads this automatically.

# --- Auth ---
JWT_SECRET=change-me-in-prod-super-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- Database ---
DATABASE_URL=sqlite:///./insider_threat.db

# --- LLM (optional) ---
# If LLM_API_KEY is empty, explain.py falls back to a deterministic template
# so the demo never breaks.
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini

# --- Blockchain ---
# Option A: Local Hardhat node (default for dev)
#RPC_URL=http://127.0.0.1:8545

# Option B: Hyperledger Besu (permissioned network)
BESU_RPC_URL=http://49.249.165.17:8080/rpc-node2/
RPC_URL=http://49.249.165.17:8080/rpc-node2/
# Private key of the account that signs transactions on Besu
PRIVATE_KEY=<your-besu-account-private-key>

# Written by blockchain/scripts/deploy.js -> ../blockchain/deployed_address.txt
# after: cd blockchain && npx hardhat run scripts/deploy.js --network besu
# Leave blank to auto-read from CONTRACT_ADDRESS_FILE below.
CONTRACT_ADDRESS=
# Path the backend reads the deployed address from if CONTRACT_ADDRESS is empty.
CONTRACT_ADDRESS_FILE=../blockchain/deployed_address.txt
# If false, chain anchoring is skipped gracefully (demo still runs).
CHAIN_ENABLED=true

# --- Demo admin (created by seed.py) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@bank.local
